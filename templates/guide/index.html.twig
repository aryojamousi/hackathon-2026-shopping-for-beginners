{% extends 'base.html.twig' %}

{% block title %}Advice & Guides{% endblock %}

{% block body %}
    <div class="tm-content-placeholder">
        <h1>Advice & Guides</h1>
        <p>Buying guides and learn articles crawled from Thomann, served from the
            separate read-only SQLite connection.</p>

        <h2>Buying Advice (Online Expert)</h2>
        {% for category, guides in guidesByCategory %}
            <section>
                <h3>
                    <a href="{{ path('app_guides_category', { category: category }) }}">{{ category }}</a>
                    {% if articleCounts[category] is defined %}
                        <small>· {{ articleCounts[category] }} Learn articles</small>
                    {% endif %}
                </h3>
                <ul>
                    {% for guide in guides %}
                        <li>
                            <a href="{{ guide.url }}" target="_blank" rel="noopener">{{ guide.title }}</a>
                            {% if guide.description %}— {{ guide.description }}{% endif %}
                        </li>
                    {% endfor %}
                </ul>
            </section>
        {% else %}
            <p>No guides found.</p>
        {% endfor %}

        <h2>Latest Learn Articles</h2>
        <ul>
            {% for article in latestArticles %}
                <li>
                    <a href="{{ article.url }}" target="_blank" rel="noopener">{{ article.title }}</a>
                    <small>[{{ article.category }}]{% if article.readingTime %} · {{ article.readingTime }} min{% endif %}</small>
                </li>
            {% else %}
                <p>No articles found.</p>
            {% endfor %}
        </ul>
    </div>
{% endblock %}
