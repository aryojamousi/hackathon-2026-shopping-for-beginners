{% extends 'base.html.twig' %}

{% block title %}{{ category }} · Advice{% endblock %}

{% block body %}
    <div class="tm-content-placeholder">
        <p><a href="{{ path('app_guides') }}">&larr; All guides</a></p>
        <h1>{{ category }}</h1>

        <h2>Buying Advice</h2>
        <ul>
            {% for guide in guides %}
                <li><a href="{{ guide.url }}" target="_blank" rel="noopener">{{ guide.title }}</a></li>
            {% else %}
                <li>No guides in this category.</li>
            {% endfor %}
        </ul>

        <h2>Learn Articles</h2>
        <ul>
            {% for article in articles %}
                <li>
                    <a href="{{ article.url }}" target="_blank" rel="noopener">{{ article.title }}</a>
                    {% if article.readingTime %}<small>· {{ article.readingTime }} min</small>{% endif %}
                    {% if article.excerpt %}<br><small>{{ article.excerpt }}</small>{% endif %}
                </li>
            {% else %}
                <li>No articles in this category.</li>
            {% endfor %}
        </ul>
    </div>
{% endblock %}
