{% extends 'base.html.twig' %}

{% block title %}Instrument Advisor{% endblock %}

{% block body %}
    <div class="tm-content-placeholder">
        <h1>Your Beginner Advisor</h1>
        <p>Tell us briefly what you have in mind — the advisor gives you recommendations
            based on Thomann's guides, Learn articles, and real products.</p>

        {% if not configured %}
            <p><strong>Note:</strong> The advisor is not configured yet.
                Set <code>OPENROUTER_API_KEY</code> in <code>.env.local</code> to
                receive recommendations.</p>
        {% endif %}

        {# data-turbo="false": Turbo rejects a 200 HTML response to a POST
           ("Form responses must redirect to another location"). Opting this
           form out lets the browser navigate normally and render the result. #}
        <form method="post" action="{{ path('app_advisor_ask') }}" data-turbo="false">
            <p>
                <label>What are you interested in?<br>
                    <select name="category" required>
                        {% for category in categories %}
                            <option value="{{ category }}">{{ category }}</option>
                        {% endfor %}
                    </select>
                </label>
            </p>
            <p>
                <label>Budget (EUR, optional)<br>
                    <input type="number" name="budget" min="0" step="10" placeholder="e.g. 300">
                </label>
            </p>
            <p>
                <label>Experience (optional)<br>
                    <input type="text" name="experience" placeholder="e.g. complete beginner">
                </label>
            </p>
            <p>
                <label>Your question<br>
                    <textarea name="question" rows="3" cols="50" placeholder="What do I need to get started?"></textarea>
                </label>
            </p>
            <p><button type="submit">Get advice</button></p>
        </form>
    </div>
{% endblock %}
