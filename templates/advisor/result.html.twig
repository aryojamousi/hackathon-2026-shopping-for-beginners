{% extends 'base.html.twig' %}

{% block title %}Beratung · {{ category }}{% endblock %}

{% block body %}
    <div class="tm-content-placeholder">
        <p><a href="{{ path('app_advisor') }}">&larr; Neue Frage</a></p>
        <h1>Beratung für: {{ category }}</h1>

        {% if error %}
            <p><strong>{{ error }}</strong></p>
        {% else %}
            <div class="tm-advice">{{ advice|nl2br }}</div>
        {% endif %}
    </div>
{% endblock %}
