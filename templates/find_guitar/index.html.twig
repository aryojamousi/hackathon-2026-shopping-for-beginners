{% extends 'base.html.twig' %}

{% block title %}Find your perfect instrument{% endblock %}

{% block body %}
{% set instruments = [
    { slug: 'electric-guitar', label: 'Electric Guitar' },
    { slug: 'acoustic-guitar', label: 'Acoustic Guitar' },
    { slug: 'drums', label: 'Drums' },
    { slug: 'piano', label: 'Piano' },
    { slug: 'singer', label: 'Singer' },
    { slug: 'dj', label: 'DJ' },
    { slug: 'producer', label: 'Producer' },
    { slug: 'violin', label: 'Violin' },
    { slug: 'trumpet', label: 'Trumpet' },
    { slug: 'marimba', label: 'Marimba' },
] %}

<style>
    .fg-page {
        max-width: 1120px;
        margin: 0 auto;
        padding: 48px 24px 72px;
        font-family: var(--tm-font, 'Open Sans', "Helvetica Neue", Helvetica, Arial, sans-serif);
        color: #1a1a1a;
    }
    .fg-title {
        margin: 0;
        font-size: 3rem;
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -.01em;
    }
    .fg-lead {
        max-width: 680px;
        margin: 16px 0 0;
        color: #3a3d42;
        font-size: 1.08rem;
        line-height: 1.5;
    }
    .fg-note-italic {
        max-width: 680px;
        margin: 12px 0 0;
        color: #b3b6ba;
        font-size: 1rem;
        font-style: italic;
        line-height: 1.5;
    }
    .fg-subhead {
        margin: 56px 0 0;
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -.01em;
    }
    .fg-subhead + .fg-lead { margin-top: 10px; }
    .fg-search {
        display: block;
        width: 100%;
        max-width: 560px;
        margin: 28px 0 0;
        padding: 15px 18px;
        border: 2px solid #1a1a1a;
        border-radius: 8px;
        font-size: 1rem;
        font-family: inherit;
        color: #1a1a1a;
    }
    .fg-search::placeholder { color: #9aa0a6; font-style: italic; }
    .fg-search:focus { outline: none; border-color: #6d28d9; }

    .fg-instruments {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 44px 24px;
        margin-top: 56px;
    }
    .fg-instrument {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        text-decoration: none;
        color: inherit;
    }
    .fg-instrument__bubble {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        background: #ececec;
        overflow: hidden;
        transition: transform .15s ease, box-shadow .15s ease;
    }
    .fg-instrument__bubble img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .fg-instrument:hover .fg-instrument__bubble {
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(0, 0, 0, .12);
    }
    .fg-instrument__label { font-size: 1rem; }

    @media (max-width: 900px) {
        .fg-instruments { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 560px) {
        .fg-title { font-size: 2.2rem; }
        .fg-instruments { grid-template-columns: repeat(2, 1fr); }
        .fg-instrument__bubble { width: 110px; height: 110px; }
    }
</style>

<div class="fg-page">
    <h1 class="fg-title">Find your perfect instrument</h1>
    <p class="fg-lead">You're new to the world of music or don't have a clue where to start? No worries!
        With a few easy questions we'll make sure to find the perfect instrument for you.</p>
    <p class="fg-note-italic">And if it doesn't fit don't be afraid to make use of our 30 day money back guarantee.</p>

    <h2 class="fg-subhead">What are you looking for?</h2>
    <p class="fg-lead">Just type in what you're looking for or directly choose an instrument category</p>

    <input type="text" class="fg-search" placeholder="Type your request" aria-label="Type your request">

    <div class="fg-instruments">
        {% for instrument in instruments %}
            <a class="fg-instrument" href="{{ path('app_beginner') }}">
                <span class="fg-instrument__bubble">
                    <img src="{{ asset('images/instruments/' ~ instrument.slug ~ '.jpg') }}" alt="{{ instrument.label }}" loading="lazy">
                </span>
                <span class="fg-instrument__label">{{ instrument.label }}</span>
            </a>
        {% endfor %}
    </div>
</div>
{% endblock %}
